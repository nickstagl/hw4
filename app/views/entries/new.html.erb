<h1>New Entry for <%= @place["name"] %></h1>

<form action="/entries" method="post" enctype="multipart/form-data">
  <input type="hidden" name="place_id" value="<%= params["place_id"] %>">

  <p>
    <label for="title_input">Title</label>
    <input type="text" name="title" id="title_input">
  </p>

  <p>
    <label for="description_input">Description</label>
    <textarea name="description" id="description_input" rows="5" cols="40"></textarea>
  </p>

  <p>
    <label for="occurred_on_input">Date</label>
    <input type="date" name="occurred_on" id="occurred_on_input">
  </p>

  <p>
    <label for="image_input">Image (optional)</label>
    <input type="file" name="image" id="image_input" accept="image/*">
  </p>

  <button>Save</button>
</form>

<p>
  <a href="/places/<%= params["place_id"] %>">Back</a>
</p>
